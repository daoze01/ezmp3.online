{
  "version": 2,
  "headers": [
    {
      "source": "/src/main.tsx",
      "headers": [
        { "key": "Content-Type", "value": "text/javascript" }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        { "key": "Content-Type", "value": "text/javascript" }
      ]
    },
    {
      "source": "/(.*).css",
      "headers": [
        { "key": "Content-Type", "value": "text/css" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/static/index.html" },
    { "source": "/(.*)", "destination": "/ezmp3-frontend/$1" }
  ]
} 