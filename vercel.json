{
  "version": 2,
  "buildCommand": "cd ezmp3-frontend && npm install && npm run build",
  "outputDirectory": "ezmp3-frontend/dist",
  "builds": [
    { "src": "static/**", "use": "@vercel/static" },
    { "src": "ezmp3-frontend/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "^/$", "dest": "/static/index.html" },
    { "src": "^/ezmp3-frontend/(.*)", "dest": "/ezmp3-frontend/$1" }
  ]
} 